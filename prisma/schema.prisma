// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// NOTE: SQLite doesn't support enums. Using String for now.

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?   
  password      String?   
  role          String    @default("CLIENT") 
  orders        Order[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Material {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  colors      Color[]
  orderFiles  OrderFile[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Color {
  id         String   @id @default(cuid())
  name       String
  hexCode    String   
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  orderFiles OrderFile[]
  isActive   Boolean  @default(true)

  @@unique([name, materialId])
}

model CarouselImage {
  id        String   @id @default(cuid())
  fileName  String
  caption   String?
  createdAt DateTime @default(now())
}

model Order {
  id                  String      @id @default(cuid())
  userId              String
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  files               OrderFile[] 
  receiptPath         String?     
  shippingMethod      String?     

  // Technical Specs (Common to all files in this quote)
  purpose             String      @default("aesthetic") 
  infillType          String      @default("auto")      
  infillPercentage    Int?        
  layerHeightType     String      @default("standard")  
  layerHeightManual   Float?      

  // Delivery Preferences
  desiredDate         DateTime?   
  deliveryNotes       String?     

  status              String      @default("PENDING_QUOTE")
  price               Float?      
  printTimeEstimated  Float?      
  estimatedDelivery   DateTime?   
  queuePosition       Int         @default(0) 
  adminNotes          String?
  trackingLink        String?
  rating              Int?
  ratingComment       String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model OrderFile {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  fileName        String
  filePath        String
  
  materialId      String?
  material        Material? @relation(fields: [materialId], references: [id])
  colorId         String?
  color           Color?    @relation(fields: [colorId], references: [id])
  
  customMaterial  String?
  customColor     String?
  
  infillType          String?
  infillPercentage    Int?
  layerHeightType     String?
  layerHeightManual   Float?
  scaleFactor         String?
  
  createdAt       DateTime  @default(now())
}

model AppSettings {
  id              String    @id @default("singleton")
  paymentAlias    String    @default("3D.PRINT.HUB.CBA")
  paymentCbu      String    @default("0000000000000000000000")
  updatedAt       DateTime  @updatedAt
}
